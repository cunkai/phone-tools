{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Android Toolbox",
  "windows": ["main", "hello"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "adb",
          "cmd": "adb",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "adb",
          "cmd": "adb",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "dialog:allow-open",
    "shell:allow-open",
    "shell:default",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read",
    "fs:allow-write",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
